NODE_ENV=development
PORT=8000

STELLAR_NETWORK=testnet

TESTNET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADX3W
MAINNET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADX3W

CACHE_TTL_SECONDS=60
HORIZON_TIMEOUT=30000

# Required for on-chain score sync (BK-7). This key signs set_score, so its
# PUBLIC key must be registered as an authorized oracle in the oracle_registry
# (Admin page → Authorize oracle). Keep the secret here only — never in the
# frontend or a commit. When unset, on-chain sync degrades to a no-op.
#
# You can reuse your admin/deployer secret here (simplest) or generate a
# dedicated oracle key (safer — a leak can only write scores, not touch admin).
# ADMIN_SECRET_KEY is still read as a fallback for older deployments.
ORACLE_SECRET_KEY=

# X402 paid-endpoint configuration (BK-8..BK-11).
# Set either PAYMENT_RECEIVE_ADDRESS explicitly, or the public key of
# ADMIN_SECRET_KEY will be used.
PAYMENT_RECEIVE_ADDRESS=
PAYMENT_AMOUNT_XLM=0.5
PAYMENT_REQUEST_TTL_SECONDS=900

# Optional LLM augmentation (BK-AI-1 / BK-AI-2). When set, /score responses
# include aiInsight + aiSuggestions rewritten by Claude. When unset, responses
# fall back to the deterministic rule-based insight/suggestion.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: override the directory used by history.service.ts (defaults to
# <cwd>/data). Useful in containerized deploys with a mounted volume.
# On Render, point this at a persistent-disk mount path so usage/feedback data
# survives redeploys and cold starts — see DEPLOYMENT_PERSISTENCE.md.
FLUXID_DATA_DIR=

# Durable metrics store (recommended for production on Render's free tier,
# whose local disk is wiped on every redeploy and cold start). When BOTH are
# set, usage events and feedback are written to Upstash Redis instead of local
# JSONL files, so the admin panel's wallet/feedback counts survive restarts.
# When unset, the service falls back to JSONL under FLUXID_DATA_DIR.
# Create a free database at https://console.upstash.com → copy the REST URL +
# token from its "REST API" section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional read-side gate for the /admin/* metrics endpoints. When set, those
# endpoints require a matching `x-admin-token` request header (the frontend
# does not send one, so leave this UNSET unless you add that header client-side
# or only call the admin API with your own tooling). When unset, /admin/* is
# open — fine for a demo, tighten before a public production launch.
ADMIN_API_TOKEN=
