# Stellar Horizon URL
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC URL
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Network Passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# FluxID backend URL — the Node/Fastify API, NOT the frontend itself.
# Local dev: backend runs on port 8000 (see backend/src/config/app.config.ts).
# If this is unset or unreachable, analyzeWallet() silently falls back to a
# simpler in-browser scoring formula whose numbers do NOT match the backend.
# Keep it set to avoid score divergence between devs.
NEXT_PUBLIC_AI_BACKEND_URL=http://localhost:8000

# Admin / deployer wallet — gates the /dashboard/admin page and its sidebar link.
# Only this wallet sees the Admin panel (usage stats, feedback, contract/backend
# controls). Falls back to the deployer key in lib/constants.ts if unset.
NEXT_PUBLIC_ADMIN_ADDRESS=GCSRZYJFQM52LSIJ4QSDK4IOHMW7PYGMUQBGWZGZSPCSIV2Y7MTVA2V3

# Deployed liquidity_identity contract ID (testnet).
NEXT_PUBLIC_CONTRACT_ID=CAUICITFNLDMHPXARAXARFBS3JKRGZZP5CE7B4DTLFBCJB5F4U24CKBP